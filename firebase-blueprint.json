{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores basic user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first logged in" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A single chat session containing multiple messages.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the owner" },
        "title": { "type": "string", "description": "Title of the chat" },
        "createdAt": { "type": "integer", "description": "Creation timestamp" },
        "updatedAt": { "type": "integer", "description": "Last message timestamp" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat session.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "ID of the parent chat" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message" },
        "text": { "type": "string", "description": "The content of the message" },
        "timestamp": { "type": "integer", "description": "Unix timestamp in milliseconds" },
        "groundingMetadata": { "type": "object", "description": "Search grounding information" }
      },
      "required": ["chatId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions for a specific user"
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat session"
    }
  }
}
